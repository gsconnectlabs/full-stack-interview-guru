# Copy to .env.local (or set in Vercel project settings).
# Leave blank to disable — nothing loads until an ID is present.

# --- Site ---
# Canonical production URL — drives metadataBase, canonicals, OG/Twitter URLs,
# sitemap, robots and structured data. No trailing slash.
# Defaults to https://fullstackinterviewguru.com when unset.
NEXT_PUBLIC_SITE_URL=https://fullstackinterviewguru.com

# Google Analytics 4 measurement ID
NEXT_PUBLIC_GA_ID=

# Google AdSense publisher ID (e.g. ca-pub-XXXXXXXXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_ID=

# --- Feedback ---
# Where the contact / feedback fallback email goes (used for mailto links).
NEXT_PUBLIC_CONTACT_EMAIL=
# Optional form backend (Formspree, Formspark, Basin, etc.). If set, the feedback
# form POSTs JSON here. If blank, the form falls back to opening the user's mail app.
NEXT_PUBLIC_FEEDBACK_ENDPOINT=

# --- Donate (all optional — only configured options render) ---
NEXT_PUBLIC_BMC_URL=          # https://www.buymeacoffee.com/yourname
NEXT_PUBLIC_KOFI_URL=         # https://ko-fi.com/yourname
NEXT_PUBLIC_GITHUB_SPONSORS=  # https://github.com/sponsors/yourname
NEXT_PUBLIC_PAYPAL_URL=       # https://paypal.me/yourname
NEXT_PUBLIC_UPI_ID=           # yourname@bank  (India UPI)

# --- Featured Products ---
# Optional Amazon Associates tag, appended to outbound product links (?tag=...).
NEXT_PUBLIC_AMAZON_TAG=       # yourtag-21
